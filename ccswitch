#!/usr/bin/env bash
set -euo pipefail

ACCOUNTS_DIR="${HOME}/.claude-accounts"
CURRENT_FILE="${ACCOUNTS_DIR}/.current"
SWITCHED_AT_FILE="${ACCOUNTS_DIR}/.switched_at"
CLAUDE_JSON="${HOME}/.claude.json"
DESKTOP_CONFIG="${HOME}/Library/Application Support/Claude/config.json"
DESKTOP_COOKIES="${HOME}/Library/Application Support/Claude/Cookies"

CODEX_JSON="${HOME}/.codex/auth.json"
CODEX_ACCOUNTS_DIR="${HOME}/.codex-accounts"

_die()         { echo "error: $*" >&2; exit 1; }
_require_jq()  { command -v jq &>/dev/null || _die "jq is required (brew install jq)"; }
_init()        { mkdir -p "${ACCOUNTS_DIR}"; chmod 700 "${ACCOUNTS_DIR}"; }
_init_codex()  { mkdir -p "${CODEX_ACCOUNTS_DIR}"; chmod 700 "${CODEX_ACCOUNTS_DIR}"; }

_current_name() {
  [[ -f "${CURRENT_FILE}" ]] && cat "${CURRENT_FILE}" || echo ""
}

_account_file() {
  echo "${ACCOUNTS_DIR}/${1}.json"
}

_account_cookies_file() {
  echo "${ACCOUNTS_DIR}/${1}.cookies"
}

# ── Claude ────────────────────────────────────────────────────────────────────

cmd_save() {
  local name="${1:-}"
  [[ -n "${name}" ]] || _die "usage: ccswitch save <name>"
  _require_jq
  _init

  [[ -f "${CLAUDE_JSON}" ]] || _die "~/.claude.json not found — are you logged in?"

  local oauth_account token_cache email keychain_creds
  oauth_account=$(jq '.oauthAccount' "${CLAUDE_JSON}")
  [[ "${oauth_account}" != "null" ]] || _die "No oauthAccount found in ~/.claude.json — are you logged in?"
  email=$(jq -r '.oauthAccount.emailAddress // "unknown"' "${CLAUDE_JSON}")

  token_cache=""
  if [[ -f "${DESKTOP_CONFIG}" ]]; then
    token_cache=$(jq -r '.["oauth:tokenCache"] // ""' "${DESKTOP_CONFIG}")
  fi

  # Capture CLI auth token from Keychain — this is what the Claude Code CLI uses for
  # actual API calls (and therefore billing). Without it, switching accounts only changes
  # the display name, not the account being billed.
  keychain_creds=$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null || echo "")

  local dest cookies_dest
  dest=$(_account_file "${name}")
  cookies_dest=$(_account_cookies_file "${name}")
  jq -n \
    --arg name "${name}" \
    --arg email "${email}" \
    --argjson oauthAccount "${oauth_account}" \
    --arg tokenCache "${token_cache}" \
    --arg keychainCredentials "${keychain_creds}" \
    '{name: $name, email: $email, oauthAccount: $oauthAccount, tokenCache: $tokenCache, keychainCredentials: $keychainCredentials}' \
    > "${dest}"
  chmod 600 "${dest}"

  # Save desktop app Cookies — holds the sessionKey that authenticates all desktop app
  # requests (including billing). Without this, only CLI credential swaps work.
  if [[ -f "${DESKTOP_COOKIES}" ]]; then
    cp "${DESKTOP_COOKIES}" "${cookies_dest}"
    chmod 600 "${cookies_dest}"
  fi

  echo "${name}" > "${CURRENT_FILE}"
  echo "saved: ${name} (${email})"
}

cmd_use() {
  local name="${1:-}"
  [[ -n "${name}" ]] || _die "usage: ccswitch use <name>"
  _require_jq

  local src
  src=$(_account_file "${name}")
  [[ -f "${src}" ]] || _die "account '${name}' not found — run: ccswitch ls"

  # Warn if a Claude CLI session is actively running
  if pgrep -f "claude" &>/dev/null; then
    echo "warning: active Claude CLI session detected — credentials will be swapped underneath it"
    read -r -p "continue anyway? [y/N] " reply
    [[ "${reply}" =~ ^[Yy]$ ]] || exit 0
  fi

  local email oauth_account token_cache keychain_creds
  email=$(jq -r '.email' "${src}")
  oauth_account=$(jq '.oauthAccount' "${src}")
  token_cache=$(jq -r '.tokenCache // ""' "${src}")
  keychain_creds=$(jq -r '.keychainCredentials // ""' "${src}")

  # Kill Claude desktop + all Claude CLI processes
  echo "stopping Claude..."
  osascript -e 'tell application "Claude" to quit' 2>/dev/null || true
  sleep 1
  pkill -f "Claude Helper" 2>/dev/null || true
  pkill -f "claude" 2>/dev/null || true   # -f catches node-spawned claude processes
  sleep 1

  # Swap oauthAccount in ~/.claude.json
  [[ -f "${CLAUDE_JSON}" ]] || _die "~/.claude.json not found"
  local tmp
  tmp=$(mktemp)
  jq --argjson oa "${oauth_account}" '.oauthAccount = $oa' "${CLAUDE_JSON}" > "${tmp}"
  mv "${tmp}" "${CLAUDE_JSON}"

  # Swap tokenCache in desktop config
  if [[ -f "${DESKTOP_CONFIG}" && -n "${token_cache}" ]]; then
    tmp=$(mktemp)
    jq --arg tc "${token_cache}" '.["oauth:tokenCache"] = $tc' "${DESKTOP_CONFIG}" > "${tmp}"
    mv "${tmp}" "${DESKTOP_CONFIG}"
  elif [[ ! -f "${DESKTOP_CONFIG}" ]]; then
    echo "note: desktop config not found at expected path — CLI credentials swapped, desktop tokenCache skipped"
  fi

  # Swap desktop app Cookies — sessionKey cookie authenticates all desktop app requests
  # including billing. Must be swapped alongside tokenCache for a complete session switch.
  local cookies_src
  cookies_src=$(_account_cookies_file "${name}")
  if [[ -f "${cookies_src}" ]]; then
    cp "${cookies_src}" "${DESKTOP_COOKIES}"
    rm -f "${DESKTOP_COOKIES}-journal" "${DESKTOP_COOKIES}-wal" "${DESKTOP_COOKIES}-shm"
  else
    echo "warning: no cookies saved for '${name}' — desktop app may bill the wrong account"
    echo "         re-save this account: ccswitch save ${name}"
  fi

  # Swap CLI auth token in Keychain — this is the Bearer token the Claude Code CLI
  # sends for API calls. Without this swap the CLI always bills the last-authed account.
  if [[ -n "${keychain_creds}" ]]; then
    if security add-generic-password -U -s "Claude Code-credentials" -a "$(whoami)" -w "${keychain_creds}" 2>/dev/null; then
      : # silent success
    else
      echo "warning: could not update keychain — CLI may bill to wrong account"
      echo "         run: ccswitch save ${name}  (to re-capture credentials)"
    fi
  else
    echo "warning: no keychain credentials saved for '${name}'"
    echo "         re-save this account: ccswitch save ${name}"
  fi

  echo "${name}" > "${CURRENT_FILE}"
  date "+%Y-%m-%d %H:%M:%S" > "${SWITCHED_AT_FILE}"
  echo "switched to: ${name} (${email})"

  # Relaunch desktop app
  read -r -p "relaunch Claude desktop app? [Y/n] " reply
  [[ "${reply}" =~ ^[Nn]$ ]] || open -a "Claude" 2>/dev/null || true
}

cmd_ls() {
  _init
  local current
  current=$(_current_name)
  local found=0
  for f in "${ACCOUNTS_DIR}"/*.json; do
    [[ -f "${f}" ]] || continue
    found=1
    local name email
    name=$(jq -r '.name' "${f}")
    email=$(jq -r '.email' "${f}")
    if [[ "${name}" == "${current}" ]]; then
      printf "* %s (%s)\n" "${name}" "${email}"
    else
      printf "  %s (%s)\n" "${name}" "${email}"
    fi
  done
  [[ "${found}" -eq 1 ]] || echo "no accounts saved — run: ccswitch save <name>"
}

cmd_status() {
  cmd_ls
  if [[ -f "${SWITCHED_AT_FILE}" ]]; then
    echo ""
    echo "last switched: $(cat "${SWITCHED_AT_FILE}")"
  fi
}

cmd_current() {
  local current
  current=$(_current_name)
  if [[ -z "${current}" ]]; then
    echo "no active account tracked"
    return
  fi
  local src email
  src=$(_account_file "${current}")
  if [[ -f "${src}" ]]; then
    email=$(jq -r '.email' "${src}")
    echo "${current} (${email})"
  else
    echo "${current}"
  fi
}

cmd_rm() {
  local name="${1:-}"
  [[ -n "${name}" ]] || _die "usage: ccswitch rm <name>"
  local src
  src=$(_account_file "${name}")
  [[ -f "${src}" ]] || _die "account '${name}' not found"
  rm "${src}"
  rm -f "$(_account_cookies_file "${name}")"
  local current
  current=$(_current_name)
  [[ "${current}" == "${name}" ]] && rm -f "${CURRENT_FILE}" || true
  echo "removed: ${name}"
}

# ── Codex ─────────────────────────────────────────────────────────────────────

cmd_codex() {
  local subcmd="${1:-}"
  case "${subcmd}" in
    save) cmd_codex_save "${2:-}" ;;
    use)  cmd_codex_use  "${2:-}" ;;
    ls)   cmd_codex_ls ;;
    rm)   cmd_codex_rm   "${2:-}" ;;
    *)
      cat <<EOF
ccswitch codex — Codex CLI account switcher

usage:
  ccswitch codex save <name>   save current Codex account
  ccswitch codex use <name>    switch to a saved Codex account
  ccswitch codex ls            list saved Codex accounts
  ccswitch codex rm <name>     remove a saved Codex account

accounts are stored in ~/.codex-accounts/
EOF
      ;;
  esac
}

cmd_codex_save() {
  local name="${1:-}"
  [[ -n "${name}" ]] || _die "usage: ccswitch codex save <name>"
  _require_jq
  _init_codex

  [[ -f "${CODEX_JSON}" ]] || _die "~/.codex/auth.json not found — are you logged in to Codex?"

  local account_id
  account_id=$(jq -r '.tokens.account_id // "unknown"' "${CODEX_JSON}")

  # Wrap the full auth.json under an "auth" key alongside our metadata
  local dest="${CODEX_ACCOUNTS_DIR}/${name}.json"
  jq -n \
    --arg name "${name}" \
    --arg account_id "${account_id}" \
    --argjson auth "$(cat "${CODEX_JSON}")" \
    '{name: $name, account_id: $account_id, auth: $auth}' \
    > "${dest}"
  chmod 600 "${dest}"

  echo "codex: saved ${name} (${account_id})"
}

cmd_codex_use() {
  local name="${1:-}"
  [[ -n "${name}" ]] || _die "usage: ccswitch codex use <name>"
  _require_jq

  local src="${CODEX_ACCOUNTS_DIR}/${name}.json"
  [[ -f "${src}" ]] || _die "codex account '${name}' not found — run: ccswitch codex ls"

  if pgrep -f "codex" &>/dev/null; then
    echo "warning: active Codex session detected — credentials will be swapped underneath it"
    read -r -p "continue anyway? [y/N] " reply
    [[ "${reply}" =~ ^[Yy]$ ]] || exit 0
  fi

  local account_id
  account_id=$(jq -r '.account_id' "${src}")

  # Kill running Codex processes
  pkill -f "codex" 2>/dev/null || true
  sleep 1

  # Write the saved auth back to ~/.codex/auth.json
  local tmp
  tmp=$(mktemp)
  jq '.auth' "${src}" > "${tmp}"
  mv "${tmp}" "${CODEX_JSON}"
  chmod 600 "${CODEX_JSON}"

  echo "codex: switched to ${name} (${account_id})"
}

cmd_codex_ls() {
  local found=0
  for f in "${CODEX_ACCOUNTS_DIR}"/*.json; do
    [[ -f "${f}" ]] || continue
    found=1
    local name account_id
    name=$(jq -r '.name' "${f}")
    account_id=$(jq -r '.account_id // "unknown"' "${f}")
    printf "  %s (%s)\n" "${name}" "${account_id}"
  done
  [[ "${found}" -eq 1 ]] || echo "no codex accounts saved — run: ccswitch codex save <name>"
}

cmd_codex_rm() {
  local name="${1:-}"
  [[ -n "${name}" ]] || _die "usage: ccswitch codex rm <name>"
  local src="${CODEX_ACCOUNTS_DIR}/${name}.json"
  [[ -f "${src}" ]] || _die "codex account '${name}' not found"
  rm "${src}"
  echo "codex: removed ${name}"
}

# ── Install ───────────────────────────────────────────────────────────────────

cmd_install() {
  local dest="${HOME}/.local/bin/ccswitch"
  local script
  script="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/ccswitch"
  [[ -f "${script}" ]] || _die "cannot find ccswitch script"
  mkdir -p "$(dirname "${dest}")"
  cp "${script}" "${dest}"
  chmod +x "${dest}"
  echo "installed to ${dest}"
}

# ── Usage ─────────────────────────────────────────────────────────────────────

usage() {
  cat <<EOF
ccswitch — Claude Code account switcher

usage:
  ccswitch save <name>     save current Claude account credentials
  ccswitch use <name>      switch to a saved Claude account
  ccswitch ls              list saved Claude accounts (* = active)
  ccswitch status          show accounts + last switch time
  ccswitch current         show active Claude account
  ccswitch rm <name>       remove a saved Claude account

  ccswitch codex <cmd>     manage Codex CLI accounts (save/use/ls/rm)

  ccswitch install         install to ~/.local/bin

Claude accounts: ~/.claude-accounts/
Codex accounts:  ~/.codex-accounts/
EOF
}

# ── Dispatch ──────────────────────────────────────────────────────────────────

case "${1:-}" in
  save)    cmd_save    "${2:-}" ;;
  use)     cmd_use     "${2:-}" ;;
  ls|list) cmd_ls ;;
  status)  cmd_status ;;
  current) cmd_current ;;
  rm)      cmd_rm      "${2:-}" ;;
  codex)   cmd_codex   "${2:-}" "${3:-}" ;;
  install) cmd_install ;;
  *)       usage ;;
esac
